generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_URL")
  directUrl = env("POSTGRES_URL")
}

// ─────────────────────────────────────────────────────────
// CORE BUSINESS
// ─────────────────────────────────────────────────────────

model Business {
  id                 String              @id @default(cuid())
  name               String
  // Extended business profile fields
  legalName          String?
  industry           String?
  businessType       String?             // "sole_trader", "company", "partnership", etc.
  currency           String              @default("USD")
  timezone           String              @default("UTC")
  country            String?
  website            String?
  phone              String?
  logoUrl            String?
  // Address
  address            String?
  city               String?
  state              String?
  postalCode         String?
  // Registration
  gstNumber          String?
  vatNumber          String?
  registrationNumber String?
  // Status
  status             String              @default("ACTIVE") // ACTIVE, SUSPENDED, CLOSED
  onboardingStep     Int                 @default(1)
  setupScore         Int                 @default(0)        // 0-100 business health score
  onboardingComplete Boolean             @default(false)

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  // Relations
  users              User[]
  categories         Category[]
  suppliers          Supplier[]
  warehouses         Warehouse[]
  products           Product[]
  inventoryMovements InventoryMovement[]
  ledgerAccounts     LedgerAccount[]
  journalEntries     JournalEntry[]
  journalLines       JournalLine[]
  auditLogs          AuditLog[]
  departments        Department[]
  employees          Employee[]
  roles              Role[]
  locations          BusinessLocation[]
  customers          Customer[]
  bankAccounts       BankAccount[]
  taxConfigurations  TaxConfiguration[]
  businessSettings   BusinessSettings?
  aiSettings         AISettings?
  knowledgeBase      BusinessKnowledgeBase?
  aiInteractions     AIInteraction[]
  aiRecommendations  AIRecommendation[]
  workflowExecutions WorkflowExecution[]
}

// ─────────────────────────────────────────────────────────
// AUTH (Better Auth - unchanged)
// ─────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  role       String    @default("EMPLOYEE")
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])

  sessions Session[]
  accounts Account[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

// ─────────────────────────────────────────────────────────
// ORGANIZATION
// ─────────────────────────────────────────────────────────

model Department {
  id                 String       @id @default(cuid())
  businessId         String
  business           Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name               String
  parentDepartmentId String?
  parentDepartment   Department?  @relation("SubDepartments", fields: [parentDepartmentId], references: [id])
  subDepartments     Department[] @relation("SubDepartments")
  employees          Employee[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  @@index([businessId])
}

model Role {
  id           String     @id @default(cuid())
  businessId   String
  business     Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  permissions  Json       @default("[]") // Array of permission keys
  isSystemRole Boolean    @default(false)
  employees    Employee[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?

  @@index([businessId])
}

model Employee {
  id                    String      @id @default(cuid())
  businessId            String
  business              Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name                  String
  email                 String
  phone                 String?
  jobTitle              String?
  departmentId          String?
  department            Department? @relation(fields: [departmentId], references: [id])
  managerId             String?
  manager               Employee?   @relation("Reports", fields: [managerId], references: [id])
  reports               Employee[]  @relation("Reports")
  roleId                String?
  role                  Role?       @relation(fields: [roleId], references: [id])
  employmentType        String      @default("FULL_TIME") // FULL_TIME, PART_TIME, CONTRACT
  status                String      @default("ACTIVE")   // ACTIVE, INACTIVE, INVITED
  hireDate              DateTime?
  emergencyContactName  String?
  emergencyContactPhone String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  deletedAt             DateTime?

  @@index([businessId])
  @@index([departmentId])
}

// ─────────────────────────────────────────────────────────
// LOCATIONS
// ─────────────────────────────────────────────────────────

model BusinessLocation {
  id             String   @id @default(cuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name           String
  type           String   @default("OFFICE") // WAREHOUSE, STORE, OFFICE, FACTORY
  address        String?
  city           String?
  state          String?
  country        String?
  postalCode     String?
  phone          String?
  operatingHours Json?    // { mon: "9-5", tue: "9-5", ... }
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@index([businessId])
}

// ─────────────────────────────────────────────────────────
// INVENTORY (extended from existing)
// ─────────────────────────────────────────────────────────

model Category {
  id               String     @id @default(cuid())
  businessId       String
  business         Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name             String
  parentCategoryId String?
  parentCategory   Category?  @relation("SubCategories", fields: [parentCategoryId], references: [id])
  subCategories    Category[] @relation("SubCategories")
  products         Product[]
  createdAt        DateTime   @default(now())
  deletedAt        DateTime?

  @@index([businessId])
}

model Supplier {
  id                String    @id @default(cuid())
  businessId        String
  business          Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name              String
  contactPerson     String?
  email             String?
  phone             String?
  address           String?
  city              String?
  country           String?
  postalCode        String?
  gstNumber         String?
  paymentTerms      String?   // "NET30", "NET60", "COD"
  leadTimeDays      Int?
  isPreferred       Boolean   @default(false)
  // NOTE: performanceRating is NOT stored here — it will be calculated
  // from orders, deliveries, and returns in a future milestone.
  products          Product[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  @@index([businessId])
}

model Warehouse {
  id         String              @id @default(cuid())
  businessId String
  business   Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  address    String?
  city       String?
  state      String?
  country    String?
  postalCode String?
  phone      String?
  isDefault  Boolean             @default(false)
  movements  InventoryMovement[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  deletedAt  DateTime?

  @@index([businessId])
}

model Product {
  id           String              @id @default(cuid())
  businessId   String
  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sku          String
  name         String
  barcode      String?
  description  String?
  categoryId   String?
  category     Category?           @relation(fields: [categoryId], references: [id])
  supplierId   String?
  supplier     Supplier?           @relation(fields: [supplierId], references: [id])
  unit         String              @default("pcs")
  costPrice    Decimal             @db.Decimal(12, 2)
  sellPrice    Decimal             @db.Decimal(12, 2)
  reorderLevel Int                 @default(0)
  movements    InventoryMovement[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?

  @@unique([businessId, sku])
  @@index([businessId])
}

model InventoryMovement {
  id            String    @id @default(cuid())
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId   String
  warehouse     Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  movementType  String
  quantity      Int
  referenceType String?
  referenceId   String?
  notes         String?
  createdBy     String
  createdAt     DateTime  @default(now())

  @@index([businessId])
  @@index([productId])
  @@index([warehouseId])
}

// ─────────────────────────────────────────────────────────
// CUSTOMERS
// NOTE: outstandingBalance is NOT stored here — it is derived
// from the finance ledger (JournalLine credits/debits) exactly
// like inventory stock levels are derived from movements.
// ─────────────────────────────────────────────────────────

model Customer {
  id           String   @id @default(cuid())
  businessId   String
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String
  email        String?
  phone        String?
  address      String?
  city         String?
  country      String?
  postalCode   String?
  gstNumber    String?
  category     String?  // "RETAIL", "WHOLESALE", "VIP"
  paymentTerms String?  // "NET30", "COD"
  creditLimit  Decimal? @db.Decimal(12, 2)
  loyaltyPoints Int     @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  @@index([businessId])
}

// ─────────────────────────────────────────────────────────
// FINANCE CONFIGURATION
// ─────────────────────────────────────────────────────────

model BankAccount {
  id             String   @id @default(cuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name           String
  accountNumber  String?
  bankName       String?
  ifscCode       String?
  currency       String   @default("USD")
  openingBalance Decimal  @db.Decimal(14, 2) @default(0)
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@index([businessId])
}

model TaxConfiguration {
  id            String   @id @default(cuid())
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  taxType       String   // "GST", "VAT", "SALES_TAX", "HST"
  name          String
  rate          Decimal  @db.Decimal(6, 3)
  hsnCode       String?
  region        String?
  invoiceFormat String?  @default("INV-[YYYY]-[0000]")
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@index([businessId])
}

model BusinessSettings {
  id               String   @id @default(cuid())
  businessId       String   @unique
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  fiscalYearStart  String   @default("01-01") // MM-DD
  accountingMethod String   @default("ACCRUAL") // ACCRUAL, CASH
  invoicePrefix    String   @default("INV")
  invoiceNextNum   Int      @default(1)
  defaultCurrency  String   @default("USD")
  dateFormat       String   @default("DD/MM/YYYY")
  openingCash      Decimal? @db.Decimal(14, 2)
  openingBank      Decimal? @db.Decimal(14, 2)
  openingReceivables Decimal? @db.Decimal(14, 2)
  openingPayables  Decimal? @db.Decimal(14, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// AI SETTINGS
// Risk-based approval thresholds (not just a single threshold number)
// ─────────────────────────────────────────────────────────

model AISettings {
  id             String   @id @default(cuid())
  businessId     String   @unique
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  // Autonomy
  autonomyLevel  String   @default("BALANCED") // MANUAL, BALANCED, AUTONOMOUS
  // Risk-based approval matrix
  riskLow        String   @default("AUTO")         // AUTO, NOTIFY, APPROVE
  riskMedium     String   @default("APPROVE")
  riskHigh       String   @default("OWNER")
  riskCritical   String   @default("OWNER_MANAGER")
  
  // Deterministic Risk Thresholds
  riskThresholdLow    Decimal  @db.Decimal(14, 2) @default(1000)
  riskThresholdMedium Decimal  @db.Decimal(14, 2) @default(10000)
  riskThresholdHigh   Decimal  @db.Decimal(14, 2) @default(50000)
  // Notifications
  notifyEmail    Boolean  @default(true)
  notifySlack    Boolean  @default(false)
  notifyWhatsApp Boolean  @default(false)
  notifySms      Boolean  @default(false)
  // Schedule
  dailyBriefTime String?  @default("09:00")
  weeklyReport   Boolean  @default(true)
  monthlyReport  Boolean  @default(true)
  // Preferences
  assistantName  String   @default("AI CEO")
  language       String   @default("en")
  automaticSuggestions Boolean @default(true)
  workStart      String   @default("09:00")
  workEnd        String   @default("18:00")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// KNOWLEDGE BASE
// ─────────────────────────────────────────────────────────
model BusinessKnowledgeBase {
  id         String   @id @default(cuid())
  businessId String   @unique
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// FINANCE LEDGER (unchanged)
// ─────────────────────────────────────────────────────────

model AuditLog {
  id               String    @id @default(cuid())
  businessId       String
  business         Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId           String?
  actorType        String    @default("USER") // "USER" or "AI"
  action           String
  entity           String
  entityId         String
  details          Json
  
  // Traceability
  executionId      String?
  workflowName     String?
  recommendationId String?
  
  createdAt        DateTime  @default(now())

  @@index([businessId])
}

model LedgerAccount {
  id              String          @id @default(cuid())
  businessId      String
  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  code            String
  name            String
  type            String
  parentAccountId String?
  parentAccount   LedgerAccount?  @relation("SubAccounts", fields: [parentAccountId], references: [id])
  subAccounts     LedgerAccount[] @relation("SubAccounts")
  isSystemAccount Boolean         @default(false)
  createdAt       DateTime        @default(now())
  deletedAt       DateTime?
  journalLines    JournalLine[]

  @@unique([businessId, code])
  @@index([businessId])
}

model JournalEntry {
  id          String        @id @default(cuid())
  businessId  String
  business    Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  entryDate   DateTime
  description String
  sourceType  String?
  sourceId    String?
  createdBy   String?
  createdAt   DateTime      @default(now())
  lines       JournalLine[]

  @@index([businessId])
  @@index([entryDate])
}

model JournalLine {
  id             String        @id @default(cuid())
  businessId     String
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  journalEntryId String
  journalEntry   JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String
  account        LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  debit          Decimal       @db.Decimal(14, 2) @default(0)
  credit         Decimal       @db.Decimal(14, 2) @default(0)
  createdAt      DateTime      @default(now())

  @@index([businessId])
  @@index([journalEntryId])
  @@index([accountId])
}

// ─────────────────────────────────────────────────────────
// AI ENGINE
// ─────────────────────────────────────────────────────────

model AIInteraction {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String?
  role       String   // "user", "assistant", "system", "tool"
  content    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([businessId])
}

model AIRecommendation {
  id             String   @id @default(cuid())
  businessId     String
  business       Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  title          String
  summary        String   @db.Text
  confidence     Int      // 0-100
  llmRisk        String   // LOW, MEDIUM, HIGH, CRITICAL
  calculatedRisk String   // LOW, MEDIUM, HIGH, CRITICAL
  finalRisk      String   // LOW, MEDIUM, HIGH, CRITICAL
  executionId    String?
  sourceModule   String   @default("CORE") // Source Module (e.g. INVENTORY, FINANCE, HR)
  
  // Explanation Fields
  why            String   @db.Text @default("")
  expectedResult String   @db.Text @default("")
  businessImpact String   @db.Text @default("")
  estimatedCost  Decimal? @db.Decimal(14, 2)
  estimatedSavings Decimal? @db.Decimal(14, 2)
  
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  executionStatus String  @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, FAILED
  requiresApproval Boolean @default(true)
  
  actionPayload  Json     // Tool execution payload
  evidence       Json     // Data supporting decision
  alternatives   Json?    
  affectedModules Json    @default("[]")
  
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?
  resolvedBy     String?

  @@index([businessId])
}

model WorkflowExecution {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  workflowName     String
  status           String   @default("RUNNING") // RUNNING, COMPLETED, FAILED
  startedAt        DateTime @default(now())
  completedAt      DateTime?
  triggerType      String   // AI, MANUAL
  recommendationId String?
  context          Json
  logs             Json
  
  @@index([businessId])
}
